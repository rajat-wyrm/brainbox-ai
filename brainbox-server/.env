# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb+srv://rajat:rajat786@cluster0.gqixk1j.mongodb.net/brainbox?retryWrites=true&w=majority
MONGODB_OPTIONS={"useNewUrlParser":true,"useUnifiedTopology":true}
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=brainbox-super-secret-key-2024-change-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7
BCRYPT_ROUNDS=12

# ============================================
# SECURITY
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
CORS_WHITELIST=http://localhost:3000,https://brainbox.ai

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_PATH=uploads/

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@brainbox.ai

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ============================================
# API KEYS
# ============================================
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
